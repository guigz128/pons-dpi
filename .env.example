# PostHog (projet "DPI" — id 182740 dans org Pons Perso)
# Valeur dans content-factory/.env sous POSTHOG_PUBLIC_KEY_PONS_DPI
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Brevo — clé API SERVEUR pour /api/contact (formulaires). NE PAS préfixer VITE_ (jamais exposée au client).
# À définir dans les Environment Variables Vercel. Brevo → SMTP & API → API Keys.
BREVO_API_KEY=
